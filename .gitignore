# 环境变量 & 密钥（绝对禁止提交）
.env
*.env
!.env.example
.dev.vars
*.dev.vars
!.dev.vars.example

# Android 本地配置（含 SDK 路径和敏感密钥）
local.properties

# IDE
.idea/
*.iml
.vscode/

# 操作系统
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node
node_modules/
dist/
.cache/

# 构建产物
build/
*.apk
*.aab
*.dex

# Cloudflare
.wrangler/